# 准备环境
sudo apt update
sudo apt install python3 python3-pip p7zip-full

# 从 GitHub 克隆工具
git clone git@github.com:platomav/BIOSUtilities.git
cd BIOSUtilities/

# 使用venv来安装依赖模块
python3 -m venv ~/venv
. ~/venv/bin/activate
python3 -m pip install --upgrade -r requirements.txt

# 好像还依赖一个biosutilities 模块
pip install biosutilities

# 执行
cd biosutilities/

# 先解压缩.exe文件，获取PFS文件，这个文件名通过 7z -l Precision_5820_2.48.0.exe 查看到的
7z e Precision_5820_2.48.0.exe "[0]"

# 提取文件
python3 dell_pfs_extract.py '[0]'
