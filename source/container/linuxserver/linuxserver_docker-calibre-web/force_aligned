calibre-backend:
    # ... 其余不变 ...
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Asia/Shanghai
      - LIBVA_DRIVER_NAME=iHD
      - render_node=/dev/dri/renderD128
      # 🪐 核心注入 1：强制客户端屏幕分辨率在万分之一秒内向 16 像素物理对齐（2560x1256 会被优雅约束为标准硬件规格）
      - force_aligned_resolution=true
      # 🪐 核心注入 2：强制开启 H.264 的全色彩范围编码，直接越过 I420 的缩放盲区
      - h264_fullcolor=true
